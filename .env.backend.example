# Backend Environment Variables - TEMPLATE
# Copy this file to .env.backend and fill in your actual values

# OpenAI API Configuration
OPENAI_API_KEY=sk-proj-your_actual_api_key_here

# Python Runtime Settings (optional - defaults handled by Docker)
# PYTHONPATH=/app
# PYTHONUNBUFFERED=1
# PYTHONDONTWRITEBYTECODE=1

# Database Configuration (uncomment if needed)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis Configuration (uncomment if needed)  
# REDIS_URL=redis://localhost:6379/0

# Application Settings (uncomment if needed)
# DEBUG=true
# LOG_LEVEL=info